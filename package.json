{
  "name": "novaa-agent",
  "version": "0.1.4",
  "description": "Next-generation AI super agent",
  "private": false,
  "bin": {
    "nova": "./cli/bin/nova.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "runtime/dist",
    "gateway/dist",
    "gateway/src",
    "agent/dist",
    "cli/dist",
    "cli/bin",
    "runtime/package.json",
    "gateway/package.json",
    "agent/package.json",
    "cli/package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "workspaces": [
    "runtime",
    "gateway",
    "agent",
    "cli"
  ],
  "scripts": {
    "build": "npm run build:gateway && npm run build:agent && npm run build:cli",
    "build:gateway": "cd gateway && npm run build",
    "build:agent": "cd agent && npm run build",
    "build:cli": "cd cli && npm run build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check:secrets": "bash scripts/check-secrets.sh",
    "dev:gateway": "cd gateway && npm run dev",
    "nova": "node cli/dist/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "example:runtime": "tsx examples/runtime-example.ts",
    "example:agent": "tsx examples/agent-example.ts",
    "demo": "tsx examples/end-to-end-demo.ts",
    "demo:autonomous": "tsx examples/autonomous-demo.ts",
    "demo:browser": "tsx examples/browser-demo.ts",
    "demo:memory": "tsx examples/memory-demo.ts",
    "demo:multi-agent": "tsx examples/multi-agent-demo.ts",
    "demo:reminders": "tsx examples/reminders-demo.ts",
    "benchmark:chat": "tsx scripts/benchmark-chat.ts"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.4.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abdulwarith001/nova.git"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "automation",
    "assistant"
  ],
  "author": "Nova Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "@mozilla/readability": "^0.6.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^12.0.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.29.0",
    "execa": "^8.0.1",
    "fastify": "^4.26.0",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.2.0",
    "gray-matter": "^4.0.3",
    "hnswlib-node": "^3.0.0",
    "inquirer": "^13.2.2",
    "isolated-vm": "^4.7.2",
    "jsdom": "^28.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "node-machine-id": "^1.1.12",
    "open": "^11.0.0",
    "openai": "^4.26.0",
    "ora": "^9.2.0",
    "pdfkit": "^0.17.2",
    "piscina": "^4.3.0",
    "playwright": "^1.58.1",
    "tsx": "^4.7.0",
    "ws": "^8.19.0",
    "zod": "^3.22.0"
  }
}
